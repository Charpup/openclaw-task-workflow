{
  "contractVersion": "2.0.0",
  "component": "task-workflow",
  "role": "DAG-based task scheduler",
  "interface": {
    "reads": {
      "triadev-handoff.json": ["planning.tasks_extracted"]
    },
    "writes": {
      "triadev-handoff.json": ["scheduling.status", "scheduling.batches"]
    },
    "capabilities": [
      "dag-scheduling",
      "complexity-scoring",
      "batch-ordering",
      "dynamic-task-insertion",
      "daily-task-persistence"
    ],
    "entrypoint": "python cli.py",
    "commands": ["init-daily", "setup-cron", "list", "add", "update", "log", "cleanup", "demo"],
    "modules": {
      "scheduler": "scripts/task_scheduler.py",
      "persistence": "scripts/task_persistence.py"
    }
  },
  "dependencies": {
    "planning-with-files": ">=2.10.0"
  }
}
